{
  "name": "centerpiece-auth",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "dependencies": {
    "@centerpiece/site-compositor": "file:../centerpiece-site-compositor"
  },
  "scripts": {
    "build": "node scripts/build-worker.js",
    "build:worker": "node scripts/build-worker.js",
    "dev": "wrangler dev dist/worker.js --port 8788",
    "deploy:staging": "npm run test:integration && npm run build && wrangler deploy --env staging",
    "deploy": "npm run test:integration && npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "tsx --tsconfig tsconfig.json --test test/**/*.test.ts",
    "test:integration": "tsx --tsconfig tsconfig.json --test test/integration.schema.test.ts",
    "db:migrate:local": "wrangler d1 migrations apply centerpiece-auth-db --local",
    "db:migrate:staging": "wrangler d1 migrations apply centerpiece-auth-db --env staging --remote",
    "db:migrate:prod": "wrangler d1 migrations apply centerpiece-auth-db --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260206.0",
    "@types/node": "^22.10.2",
    "better-sqlite3": "^12.10.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "wrangler": "^4.14.0"
  }
}
