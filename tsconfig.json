{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@centerpiece/site-compositor": ["../centerpiece-site-compositor/src/index.ts"],
      "@centerpiece/site-compositor/security": ["../centerpiece-site-compositor/src/security/index.ts"]
    },
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
